{
  "name": "houston-ai",
  "version": "0.4.26",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --write --error-on-warnings",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:parity": "node scripts/check-parity.mjs",
    "prepare": "husky || true",
    "test": "pnpm -r --if-present --no-bail test",
    "dev": "mprocs",
    "dev:host": "HOUSTON_HOST_TOKEN=devtoken HOUSTON_HOST_PORT=4318 pnpm --filter @houston/host dev",
    "dev:app": "cd app && VITE_NEW_ENGINE_URL=http://127.0.0.1:4318 VITE_NEW_ENGINE_TOKEN=devtoken VITE_HOSTED_ENGINE_URL= pnpm tauri dev",
    "dev:gateway": "CP_DEV=1 CP_PORT=8090 pnpm --filter @houston/host-cloud dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "mprocs": "^0.9.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^6.0.2",
    "@types/node": "^22",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": "biome check --write --no-errors-on-unmatched --error-on-warnings"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
