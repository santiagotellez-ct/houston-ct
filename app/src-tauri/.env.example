# Copy to app/.env.local or app/src-tauri/.env.local for local builds.
# Never commit real values.

# In-app "Report bug" issues
LINEAR_API_KEY=lin_api_your_key
LINEAR_TEAM_ID=your-linear-team-uuid
LINEAR_BUG_LABEL_NAME=User Bug

# Optional product infrastructure
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
SENTRY_DSN=
# Dev builds suppress Sentry by default so dev errors don't pollute the prod
# project. Set to 1 (or true/yes/on) to send + symbolicate from `pnpm tauri dev`
# while testing crash reporting. Ignored by release builds.
SENTRY_SEND_IN_DEV=
